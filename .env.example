# Warden — Configuración de integración con el Cerebro
# Copia a .env y ajusta los valores

# URL del Orquestador (Cerebro)
CEREBRO_URL=http://localhost:4000

# Puerto en el que Warden expone su servidor HTTP (modo agente)
WARDEN_PORT=4003

# Si debe reportar eventos al Cerebro (true/false)
CEREBRO_REPORT_ENABLED=true
