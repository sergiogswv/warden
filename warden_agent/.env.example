# Warden ADK Agent — Configuración
# Copia este archivo como .env y ajusta los valores

# --- Warden Core (Rust) ---
WARDEN_CORE_URL=http://localhost:4003

# --- Cerebro (Orquestador) ---
CEREBRO_URL=http://localhost:4000

# --- Proveedor de LLM ---
# Opciones: gemini | claude | openai | ollama
LLM_PROVIDER=gemini

# Google Gemini (si usar gemini)
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude (si usar claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-latest

# OpenAI (si usar openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Ollama — sin API key, corre local
# Asegúrate de tener Ollama corriendo: ollama serve
# Descarga el modelo: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- ADK Server (este proceso) ---
WARDEN_ADK_PORT=4013

# --- Memoria persistente ---
WARDEN_DB_PATH=./warden_memory.db
